pipeline {
    agent any

    environment {
        DOCKER_USER = 'lokesh815'
        IMAGE_BACKEND = "${DOCKER_USER}/mern-backend"
        IMAGE_FRONTEND = "${DOCKER_USER}/mern-frontend"
    }

    stages {

        stage('Checkout') {
            steps {
                git branch: 'main', url: 'https://github.com/loke815/MERN-docker-compose.git'
            }
        }

        stage('Build Backend') {
            steps {
                dir('backend') {
                    sh 'docker build -t mern-backend .'
                }
            }
        }

        stage('Build Frontend') {
            steps {
                dir('frontend') {
                    sh 'docker build -t mern-frontend .'
                }
            }
        }

        stage('Push Images') {
            steps {
                script {
                    docker.withRegistry('', 'dockerhub-creds') {
                        sh 'docker push mern-backend '
                        sh 'docker push mern-frontend'
                    }
                }
            }
        }

        stage('Deploy to Kubernetes') {
            steps {
                sh 'kubectl apply -f k8s/'
            }
        }
    }
}
